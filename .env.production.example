# =============================================================================
# QC Management Tool - Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in all values before deploying.
# DO NOT commit .env to version control.
# =============================================================================

# === Docker Hub ===
DOCKER_HUB_USERNAME=

# === Domains (used by Traefik labels) ===
WEB_DOMAIN=gerbil.qc
API_DOMAIN=api.gerbil.qc

# === Supabase Database ===
SUPABASE_DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# === Local PostgreSQL (for n8n only) ===
POSTGRES_USER=qc_admin
POSTGRES_PASSWORD=
POSTGRES_DB=qc_app

# === Application ===
JWT_SECRET=
NODE_ENV=production
CORS_ORIGIN=https://gerbil.qc

# === External n8n (running in separate compose, reachable via qc-shared-network) ===
N8N_WEBHOOK_URL=http://n8n:5678/webhook

# === Backups ===
BACKUP_PATH=./backups
BACKUP_RETENTION_DAYS=7