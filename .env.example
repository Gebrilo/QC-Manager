# =============================================================================
# QC Management Tool - Development Environment Variables
# =============================================================================
# Copy this file to .env and fill in values for local development.
# The docker-compose.override.yml provides sensible defaults for most values.
# =============================================================================

# === Database ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=qc_app

# === Application ===
JWT_SECRET=dev-secret-not-for-production-use-only
NEXT_PUBLIC_API_URL=http://localhost:3001

# === External n8n (optional, leave empty to mock in dev) ===
N8N_WEBHOOK_URL=

# === Supabase ================================================================
# Set DATABASE_URL to the Supabase direct connection string to use Supabase DB
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
# Also used for the n8n "QC Supabase Postgres" credential (configure in n8n UI)
SUPABASE_DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Frontend (Next.js) - safe to expose (anon key only)
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# === Tuleap Integration ===
TULEAP_BASE_URL=https://tuleap.windinfosys.com
TULEAP_ACCESS_KEY=tlp-k1-your-personal-access-key
TULEAP_DEFAULT_PROJECT_ID=101
TULEAP_TRACKER_TASK=5
TULEAP_TRACKER_USER_STORY=6
TULEAP_TRACKER_TEST_CASE=9
TULEAP_TRACKER_BUG=1
