# =============================================================================
# QC Management Tool - Development Environment Variables
# =============================================================================
# Copy this file to .env and fill in values for local development.
# The docker-compose.override.yml provides sensible defaults for most values.
# =============================================================================

# === Database ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=qc_app

# === Application ===
JWT_SECRET=dev-secret-not-for-production-use-only
NEXT_PUBLIC_API_URL=http://localhost:3001

# === External n8n (optional, leave empty to mock in dev) ===
N8N_WEBHOOK_URL=

# === Supabase ================================================================
# Set DATABASE_URL to the Supabase direct connection string to use Supabase DB
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Frontend (Next.js) - safe to expose (anon key only)
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...